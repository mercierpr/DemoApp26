<Page x:Class="DemoApp26.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoApp26.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrdersPage">

    <Grid Background="white">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Cursor="Hand">
            <Button Background="#00FA9A" Width="55" Content="Назад" Margin="5" Click="GoBack_Click" x:Name="GoBack"/>
            <Button Background="#7FFF00" Width="110" Content="Добавить заказ" Margin="5" Click="AddOrder_Click" x:Name="AddOrder"/>
        </StackPanel>
        <ListView Grid.Row="1" ItemsSource="{Binding OrdersList}" x:Name="OrdersList" HorizontalContentAlignment="Stretch">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate >
                    <StackPanel Width="auto"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate >
                    <Grid MouseLeftButtonUp="EditOrder_Click" Cursor="Hand">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding articul}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding status}"/>
                            <TextBlock Text="{Binding pvz}"/>
                            <TextBlock Text="{Binding date_order}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding date_delivery}" FontWeight="Bold"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
