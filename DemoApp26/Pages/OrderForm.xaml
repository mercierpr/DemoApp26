<Page x:Class="DemoApp26.Pages.OrderForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoApp26.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderForm">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Button Background="#00FA9A" Width="55" Content="Назад" Margin="10,10,735,110" Click="GoBack_Click" x:Name="GoBack"/>
        <StackPanel Grid.RowSpan="2" VerticalAlignment="Center" Width="200">
                <TextBlock Text="Артикул" Margin="0 5 0 5"/>
                <TextBox Name="TextBoxArticul" Text="{Binding articul}"/>
                <TextBlock Text="Статус" Margin="0 5 0 5"/>
                <ComboBox Name="ComboBoxStatus" Text="{Binding status}"/>
                <TextBlock Text="Адрес ПВЗ" Margin="0 5 0 5"/>
                <TextBox Name="TextBoxPvz" Text="{Binding pvz}"/>
                <TextBlock Text="Дата заказа" Margin="0 5 0 5"/>
                <DatePicker Name="TextBoxDateOrder" Text="{Binding date_order}"/>
                <TextBlock Text="Дата выдачи" Margin="0 5 0 5" />
                <DatePicker Name="TextBoxDateDelivery" Text="{Binding date_delivery}"/>
            </StackPanel>
        <StackPanel Grid.Row="2">
            <Button Background="#7FFF00" Content="Сохранить" Margin="0,10,0,0" Width="136" Height="37" Click="ButtonSave_Click" Cursor="Hand"/>
            <Button Background="#00FA9A" Content="Удалить" Margin="0,10,0,0" Width="104" Height="27" Click="ButtonDel_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>
