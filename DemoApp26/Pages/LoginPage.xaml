<Page x:Class="DemoApp26.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoApp26.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="#FFFFFF">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Логин" Margin="0,0,0,5" />
            <TextBox Name="loginInput" TextWrapping="Wrap" Width="120" Margin="0,0,0,10" />
            <Label Content="Пароль"/>
            <TextBox Name="passwordInput" TextWrapping="Wrap" Width="120" Margin="0,0,0,10"/>
            <Button Content="Button" HorizontalAlignment="Left" Width="120" Height="30" Background="Chartreuse" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
