<Page x:Class="DemoApp26.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoApp26.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserPage">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button Background="#00FA9A" Width="55" Content="Назад" Margin="5" Click="GoBack_Click" x:Name="GoBack"/>
        </StackPanel>
        <ListView Grid.Row="1" ItemsSource="{Binding ProductsList}" x:Name="ProductsList" HorizontalContentAlignment="Stretch">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate >
                    <StackPanel Width="auto"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemTemplate>
                <DataTemplate >
                    <Grid Cursor="Hand">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{Binding photo_url}" Width="300" Height="200" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Fill"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding name, StringFormat='Наименование: {0}'}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding category, StringFormat='Категория: {0}'}"/>
                            <TextBlock Text="{Binding description, StringFormat='Описание: {0}'}"/>
                            <TextBlock Text="{Binding manufacturer, StringFormat='Производитель: {0}'}"/>
                            <TextBlock Text="{Binding supplier, StringFormat='Поставщик: {0}'}"/>
                            <TextBlock Text="{Binding price, StringFormat='Цена: {0}'}"/>
                            <TextBlock Text="{Binding edizm, StringFormat='Единица измерения: {0}'}"/>
                            <TextBlock Text="{Binding count, StringFormat='Количество на складе: {0}'}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding sale}" FontWeight="Bold"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
