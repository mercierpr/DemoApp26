<Page x:Class="DemoApp26.Pages.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DemoApp26.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserPage">

    <Grid Background="White">
        <DataGrid x:Name="UserProductsList" d:ItemsSource="{d:SampleData ItemCount=5}" DataContext="{Binding ElementName=dataGridTextColumn, Mode=OneWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding name}" Width="100"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding price}" Width="100"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding manufacturer}" Width="100"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding category}" Width="100"/>
                <DataGridTextColumn x:Name="dataGridTextColumn" Header="Описание" Binding="{Binding description}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
